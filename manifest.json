{
  "manifest_version": 3,
  "name": "JobHub",
  "version": "1.0.1",
  "description": "简历一键填充 + 投递记录追踪 + 求职数据看板，同步飞书多维表格",
  "author": "Zheyi-D",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "JobHub — 求职助手"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/fill-engine.js"],
      "run_at": "document_end"
    }
  ],

  "options_page": "options/options.html"
}
